<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.input.KeyCodeCombination?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bookingsgui.HelloController">
    <MenuBar>
        <Menu text="Fájl">
            <MenuItem text="Megnyitás" onAction="#onOpenClick">
                <accelerator>
                    <KeyCodeCombination alt="UP" code="O" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                </accelerator>
            </MenuItem>
            <MenuItem text="Kilépés" onAction="#onExitClick" />
        </Menu>
        <Menu text="Súgó">
            <MenuItem text="Névjegy" onAction="#onAboutClick" />
        </Menu>
    </MenuBar>

    <HBox spacing="20.0" alignment="CENTER_LEFT">
        <padding>
            <Insets left="10.0" />
        </padding>
        <RadioButton fx:id="rbYears" text="Évek" selected="true">
            <toggleGroup>
                <ToggleGroup fx:id="filterGroup" />
            </toggleGroup>
        </RadioButton>
        <RadioButton fx:id="rbHotels" text="Hotelek" toggleGroup="$filterGroup" />
    </HBox>

    <HBox spacing="15.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" />
        </padding>
        <ListView fx:id="leftList" prefWidth="200.0" prefHeight="350.0" VBox.vgrow="ALWAYS" />
        <ListView fx:id="rightList" prefWidth="400.0" prefHeight="350.0" HBox.hgrow="ALWAYS" />
    </HBox>
</VBox>