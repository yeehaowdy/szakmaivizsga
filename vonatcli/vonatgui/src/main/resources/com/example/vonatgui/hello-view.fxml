               </items>
          </Menu>
        </menus>
      </MenuBar>
      <ToolBar prefHeight="40.0" prefWidth="200.0">
         <items>
            <Label text="Category:" />
            <ComboBox id="cbx_category" fx:id="cbx_category" prefWidth="150.0" promptText="C" />
         </items>
      </ToolBar>
      <SplitPane dividerPositions="0.29797979797979796" minHeight="300.0" prefHeight="160.0" prefWidth="200.0">
        <items>
          <AnchorPane maxWidth="200.0" minHeight="300.0" minWidth="200.0" prefHeight="160.0" prefWidth="100.0">
               <children>
                  <ListView id="lv_left" fx:id="lv_left" maxWidth="200.0" minHeight="300.0" prefHeight="200.0" prefWidth="200.0" />
               </children>
            </AnchorPane>
          <AnchorPane minHeight="300.0" minWidth="400.0" prefHeight="160.0" prefWidth="100.0">
               <children>
                  <ListView id="lv_right" fx:id="lv_right" minHeight="300.0" minWidth="400.0" prefHeight="200.0" prefWidth="200.0" />
               </children>
            </AnchorPane>
        </items>
      </SplitPane>
   </children>
