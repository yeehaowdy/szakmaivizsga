<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.bookgui.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Book Analysis System">
        <font>
            <Font name="System Bold" size="18.0"/>
        </font>
    </Label>

    <Button text="Load and Analyze Data" onAction="#onAnalyzeButtonClick"/>

    <TextArea fx:id="resultArea" editable="false" prefHeight="400.0" prefWidth="500.0"
              font="Consolas" wrapText="true"/>
</VBox>
