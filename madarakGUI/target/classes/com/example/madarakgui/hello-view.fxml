<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>

<BorderPane fx:controller="com.example.madarakgui.HelloController"
            xmlns:fx="http://javafx.com/fxml" prefWidth="600" prefHeight="400">
    <top>
        <VBox>
            <MenuBar>
                <menus>
                    <Menu text="Fájl">
                        <items>
                            <MenuItem fx:id="menuMegnyitas" text="Megnyitás" />
                            <MenuItem fx:id="menuKilepes" text="Kilépés" />
                        </items>
                    </Menu>
                    <Menu text="Súgó">
                        <items>
                            <MenuItem fx:id="menuNevjegy" text="Névjegy" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <!-- Szűrés sor -->
            <HBox spacing="5" alignment="CENTER_LEFT" padding="10">
                <Label text="Súly:"/>
                <TextField fx:id="txtMin" prefWidth="50" alignment="CENTER"/>
                <Label text="-"/>
                <TextField fx:id="txtMax" prefWidth="50" alignment="CENTER"/>
                <Button fx:id="btnSzures" text="Szűrés" prefWidth="75"/>
                <Button fx:id="btnMind" text="Mind" prefWidth="75"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ListView fx:id="lstMadarak">
            <BorderPane.margin>
                <Insets top="5" right="10" bottom="10" left="10"/>
            </BorderPane.margin>
        </ListView>
    </center>

</BorderPane>
